# =============================================================================
# REQUIRED (here OR in repo root `../.env`)
# =============================================================================

# PostgreSQL (Prisma). Nest preload loads root `.env` then this file.
# Raw `npx prisma` from `backend/` only reads `backend/.env` — set DATABASE_URL here
# OR always use: `npm run prisma:generate`, `npm run prisma:migrate`, etc. (they load `../.env`).
# DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/zeyago?schema=public"

# =============================================================================
# SERVER (optional — defaults shown)
# =============================================================================

PORT=3000
NODE_ENV=development

# Auth/session
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
ADMIN_PHONE_NUMBERS=
AUTH_ALLOW_TEST_OTP=true
AUTH_TEST_OTP_CODE=123456

# Comma-separated browser origins for CORS (Vite dev server, admin UI).
# If unset, falls back to APP_PUBLIC_URL then localhost:5173 — see main.ts
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Public URLs (no trailing slashes). Used in API root JSON, storage URLs, redirects.
API_PUBLIC_URL=http://localhost:3000
APP_PUBLIC_URL=http://localhost:5173
ADMIN_PUBLIC_URL=http://localhost:5173

# =============================================================================
# STORAGE — all config from env; business code uses StorageService only
# =============================================================================
# STORAGE_DRIVER: "local" | "s3" (S3-compatible: MinIO, AWS S3, etc.)

STORAGE_DRIVER=local
# Base URL for public object links (served under /storage/objects/... when local)
STORAGE_PUBLIC_BASE_URL=http://localhost:3000
# Root directory for local driver (created if missing)
STORAGE_LOCAL_ROOT=./storage

# --- S3-compatible (set STORAGE_DRIVER=s3; required when using MinIO) ---
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Typical for MinIO: true
S3_FORCE_PATH_STYLE=true

# =============================================================================
# OPTIONAL — app behaviour
# =============================================================================

DEMO_AUTO_TRIP_PROGRESS=false
NOTIFICATION_PROVIDER=log

# When using a pooled DB (PgBouncer), add to prisma/schema.prisma:
#   directUrl = env("DIRECT_URL")
# Then set DIRECT_URL to a non-pooled connection for migrations.
# DIRECT_URL=
