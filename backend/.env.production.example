# Example shape for a future production deployment — values are placeholders only.
# Switch hosts/buckets without changing Nest business logic (rides, wallet, admin).

NODE_ENV=production
PORT=3000
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
ADMIN_PHONE_NUMBERS=+251911223344
AUTH_ALLOW_TEST_OTP=true
AUTH_TEST_OTP_CODE=1234
NOTIFICATION_PROVIDER=log

# Managed Postgres — connection string from provider dashboard
DATABASE_URL="postgresql://USER:PASSWORD@db.example.com:5432/zeyago?schema=public&sslmode=require"

# Tight CORS: your real web app and admin origins only
CORS_ORIGINS=https://app.example.com,https://admin.example.com
API_PUBLIC_URL=https://api.example.com
APP_PUBLIC_URL=https://app.example.com
ADMIN_PUBLIC_URL=https://admin.example.com

# S3-compatible (AWS S3, MinIO, R2, etc.)
STORAGE_DRIVER=s3
STORAGE_PUBLIC_BASE_URL=https://cdn.example.com
STORAGE_LOCAL_ROOT=./storage

S3_ENDPOINT=https://s3.eu-west-1.amazonaws.com
S3_REGION=eu-west-1
S3_BUCKET=zeyago-prod-assets
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=false
