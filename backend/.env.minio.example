# Example: local Postgres + MinIO (S3-compatible) for object storage.
# Copy relevant lines into `.env` or `.env.local`.

NODE_ENV=development
PORT=3000
JWT_SECRET=dev-only-secret-change-me
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
ADMIN_PHONE_NUMBERS=+251911223344
AUTH_ALLOW_TEST_OTP=true
AUTH_TEST_OTP_CODE=1234
NOTIFICATION_PROVIDER=log

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/zeyago?schema=public"

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
API_PUBLIC_URL=http://localhost:3000
APP_PUBLIC_URL=http://localhost:5173
ADMIN_PUBLIC_URL=http://localhost:5173

STORAGE_DRIVER=s3
# Public URL prefix for stored objects (often MinIO console URL + bucket path or CDN)
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/your-bucket
STORAGE_LOCAL_ROOT=./storage

# MinIO default API port is 9000
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=your-bucket
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
