# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Mapbox public token for mobile map (Mapbox GL JS). Optional until you enable live maps.
VITE_MAPBOX_ACCESS_TOKEN=""

# Local Nest API (Vite mobile app). Point `VITE_API_BASE_URL` at the backend; disable mocks for real HTTP.
# Do not set this to the Vite URL (5173) unless you rely on `server.ts` proxying /admin/* to Nest.
VITE_USE_MOCK_API="false"
VITE_API_BASE_URL="http://localhost:3001"
NEST_API_PORT=3001

# Realtime gateway (WebSocket / Socket.IO) — placeholders; no connection until implemented in realtimeClient.
VITE_REALTIME_ENABLED="false"
VITE_REALTIME_URL=""
VITE_REALTIME_RECONNECT_STRATEGY="none"
VITE_REALTIME_RECONNECT_BASE_DELAY_MS="2000"
VITE_REALTIME_MAX_RECONNECT_ATTEMPTS="8"
# Optional dev token for socket auth experiments (use session token in production).
VITE_REALTIME_DEV_TOKEN=""
